---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

// 1. Fetch events
const events = await getCollection("events");

// 2. Separate upcoming/ongoing and past events
const today = new Date();
today.setHours(0, 0, 0, 0); // Normalize time to start of day for comparison

const upcomingEvents = events.filter(event => new Date(event.data.date) >= today);
const pastEvents = events.filter(event => new Date(event.data.date) < today);

// Sort upcoming: closest to today first (ascending)
upcomingEvents.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

// Sort past: newest first (descending)
pastEvents.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout pageTitle="Events">
  <main class="max-w-4xl mx-auto px-6 pt-32 pb-24">
    
    <!-- Page Header -->
    <div class="mb-16 text-center">
      <span class="block text-[#F85E00] font-semibold tracking-wider uppercase text-sm mb-2">
        EEA Events
      </span>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-[color:var(--text-primary)] mb-4">
        What's Happening
      </h1>
      <p class="text-xl text-[color:var(--text-secondary)] font-normal max-w-xl mx-auto">
        Join our upcoming workshops and browse our archive of past tech fests and talks.
      </p>
    </div>

    <!-- 1. Upcoming & Ongoing Events Section -->
    <div class="mb-20">
      <h2 class="text-2xl font-bold tracking-tight text-[color:var(--text-primary)] mb-8 flex items-center gap-3">
        <span class="w-2.5 h-2.5 bg-green-500 rounded-full animate-ping"></span>
        Upcoming & Ongoing Events
      </h2>

      {upcomingEvents.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {upcomingEvents.map((event) => {
            const formattedDate = new Date(event.data.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            });

            return (
              <a 
                href={`/events/${event.slug}`}
                class="group relative block bg-[color:var(--glass-bg)] border border-[#F85E00]/20 hover:border-[#F85E00]/50 rounded-3xl p-6 backdrop-blur-[24px] shadow-[color:var(--glass-shadow)] transition-all duration-300 hover:shadow-[0_8px_32px_rgba(248,94,0,0.1)] hover:-translate-y-1 flex flex-col justify-between h-full"
              >
                <!-- Glowing indicator badge -->
                <div class="absolute top-4 right-4">
                  <span class="px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded-full bg-[#F85E00]/10 text-[#F85E00] border border-[#F85E00]/20">
                    Upcoming
                  </span>
                </div>

                <div>
                  {event.data.location && (
                    <span class="block text-xs font-semibold text-[color:var(--text-secondary)]/50 tracking-wider uppercase mb-2">
                      📍 {event.data.location}
                    </span>
                  )}
                  <h3 class="text-xl font-bold tracking-tight text-[color:var(--text-primary)] group-hover:text-[#F85E00] transition-colors duration-300 pr-16">
                    {event.data.title}
                  </h3>
                  <p class="mt-2 text-sm text-[color:var(--text-secondary)] font-normal leading-relaxed">
                    {event.data.description}
                  </p>
                </div>

                <div class="mt-6 flex items-center justify-between border-t border-[color:var(--glass-border)] pt-4">
                  <span class="text-xs font-bold text-[#F85E00] uppercase tracking-wider">
                    {formattedDate}
                  </span>
                  <span class="text-xs font-semibold text-[color:var(--text-primary)] flex items-center gap-1 group-hover:text-[#F85E00] transition-colors">
                    Register Now
                    <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="bg-[color:var(--glass-bg)] border border-[color:var(--glass-border)] rounded-3xl p-8 text-center text-[color:var(--text-secondary)] backdrop-blur-[24px]">
          No upcoming events scheduled at the moment. Check back later!
        </div>
      )}
    </div>

    <!-- 2. Past Events Timeline Section -->
    <div>
      <h2 class="text-2xl font-bold tracking-tight text-[color:var(--text-primary)] mb-10">
        Past Events
      </h2>

      {pastEvents.length > 0 ? (
        <div id="timeline-track" class="relative border-l border-[color:var(--glass-border)] ml-6 md:ml-48 pl-8 md:pl-12 space-y-16 py-8">
          
          <!-- Floating Scroll-Follower Ball -->
          <div 
            id="timeline-follower" 
            class="absolute left-[-9px] top-0 w-4.5 h-4.5 bg-[#F85E00] rounded-full shadow-[0_0_15px_#F85E00] z-20 pointer-events-none"
            style="transform: translateY(0px);"
          ></div>

          {pastEvents.map((event) => {
            const formattedDate = new Date(event.data.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            });

            return (
              <div class="relative group">
                <!-- Subtle Static Node Marker -->
                <div class="absolute left-[-35px] md:left-[-52px] top-5 w-2 h-2 bg-[color:var(--text-secondary)]/30 rounded-full z-10"></div>
                
                <!-- Date displayed on the left (Desktop) -->
                <div class="absolute left-[-240px] top-3 text-right hidden md:block w-40 text-sm font-semibold text-[color:var(--text-secondary)]/80 uppercase tracking-wider group-hover:text-[#F85E00] transition-colors duration-300">
                  {formattedDate}
                </div>
                
                <!-- Date displayed above card (Mobile) -->
                <div class="md:hidden text-xs font-semibold text-[#F85E00] uppercase tracking-wider mb-2">
                  {formattedDate}
                </div>
                
                <!-- Event Card -->
                <a 
                  href={`/events/${event.slug}`} 
                  class="block bg-[color:var(--glass-bg)] border border-[color:var(--glass-border)] rounded-3xl p-6 md:p-8 backdrop-blur-[24px] shadow-[color:var(--glass-shadow)] transition-all duration-300 hover:border-[#F85E00]/30 hover:bg-white/[0.04] hover:-translate-y-1 max-w-xl"
                >
                  {event.data.location && (
                    <span class="block text-xs font-semibold text-[color:var(--text-secondary)]/50 tracking-wider uppercase mb-2">
                      📍 {event.data.location}
                    </span>
                  )}
                  
                  <h3 class="text-xl md:text-2xl font-bold tracking-tight text-[color:var(--text-primary)] group-hover:text-[#F85E00] transition-colors duration-300">
                    {event.data.title}
                  </h3>
                  
                  <p class="mt-3 text-base text-[color:var(--text-secondary)] font-normal leading-relaxed">
                    {event.data.description}
                  </p>

                  {event.data.tags && (
                    <div class="mt-6 flex flex-wrap gap-2">
                      {event.data.tags.map((tag) => (
                        <span class="px-2.5 py-1 text-xs bg-[color:var(--glass-bg)] text-[color:var(--text-secondary)]/80 border border-[color:var(--glass-border)] rounded-full">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="text-center text-[color:var(--text-secondary)]">
          No past events recorded.
        </div>
      )}
    </div>

  </main>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('load', () => {
    const track = document.getElementById("timeline-track");
    const follower = document.getElementById("timeline-follower");

    if (track && follower) {
      // Animate the single orange ball down the timeline line based on scroll
      gsap.to(follower, {
        y: () => track.offsetHeight - 18, // Height of track minus height of follower ball (18px)
        ease: "none",
        scrollTrigger: {
          trigger: track,
          start: "top 40%",
          end: "bottom 60%",
          scrub: true,
          invalidateOnRefresh: true
        }
      });
    }
  });
</script>