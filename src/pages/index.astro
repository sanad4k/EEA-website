---
import Layout from "../layouts/Layout.astro";
import Quotes from "../components/Quotes.astro";
import BinaryTextReveal from "../components/BinaryTextReveal.astro";
import SectionInterviews from "../components/SectionInterviews.astro";
import Intro from "../components/Intro.astro";
import Placements from "../components/Placements.astro";
import { getCollection } from "astro:content";

// 1. Fetch events
const events = await getCollection("events");

// 2. Separate upcoming/ongoing events
const today = new Date();
today.setHours(0, 0, 0, 0);

const upcomingEvents = events.filter(event => new Date(event.data.date) >= today);
upcomingEvents.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

// Slice to show at most the nearest 2 upcoming events
const featuredUpcoming = upcomingEvents.slice(0, 2);

// 3. Social connections array (flexible and editable to add more links)
const socials = [
  {
    name: "Instagram",
    url: "https://www.instagram.com/nitc_eea/",
    icon: "instagram",
    description: "Follow us for event updates, highlights, and community snapshots.",
  },
  {
    name: "NITC Website",
    url: "https://nitc.ac.in/",
    icon: "globe",
    description: "Official portal of the National Institute of Technology, Calicut.",
  }
];
---

<Layout>
	<section class="h-24 md:h-32"></section> 

	<!-- Mechanical Board & Inspiration Hero Area -->
	<div class="max-w-4xl mx-auto px-6 flex flex-col items-center">
		<BinaryTextReveal />
		<Quotes />
	</div>

	<!-- Staggered narrative intro -->
	<Intro />

	<!-- Side-by-Side Placement & Interview Hubs -->
	<div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8 mb-24 mt-8">
		<div class="bg-[color:var(--glass-bg)] border border-[color:var(--glass-border)] rounded-3xl backdrop-blur-[24px] shadow-[color:var(--glass-shadow)] hover:border-[#F85E00]/30 transition-all duration-300 flex flex-col justify-between h-full">
			<SectionInterviews />
		</div>
		<div class="bg-[color:var(--glass-bg)] border border-[color:var(--glass-border)] rounded-3xl backdrop-blur-[24px] shadow-[color:var(--glass-shadow)] hover:border-[#F85E00]/30 transition-all duration-300 flex flex-col justify-between h-full">
			<Placements />
		</div>
	</div>

	<!-- Upcoming Events Section -->
	<div class="max-w-4xl mx-auto px-6 mb-32">
		<div class="flex items-center justify-between mb-8">
			<h2 class="text-2xl md:text-3xl font-bold tracking-tight text-[color:var(--text-primary)] flex items-center gap-2.5">
				<span class="relative flex h-2.5 w-2.5">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
				</span>
				Upcoming Events
			</h2>
			<a href="/events" class="text-sm font-semibold text-[#F85E00] hover:underline flex items-center gap-1 group transition-colors">
				View Timeline
				<svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
			</a>
		</div>

		{featuredUpcoming.length > 0 ? (
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{featuredUpcoming.map((event) => {
					const formattedDate = new Date(event.data.date).toLocaleDateString("en-US", {
						year: "numeric",
						month: "short",
						day: "numeric",
					});

					return (
						<a 
							href={`/events/${event.slug}`}
							class="group relative block bg-[color:var(--glass-bg)] border border-[color:var(--glass-border)] hover:border-[#F85E00]/30 rounded-3xl p-6 backdrop-blur-[24px] shadow-[color:var(--glass-shadow)] transition-all duration-300 hover:shadow-[0_8px_32px_rgba(248,94,0,0.1)] hover:-translate-y-1 flex flex-col justify-between min-h-[180px]"
						>
							<div>
								{event.data.location && (
									<span class="block text-xs font-semibold text-[color:var(--text-secondary)]/50 tracking-wider uppercase mb-2">
										📍 {event.data.location}
									</span>
								)}
								<h3 class="text-lg font-bold tracking-tight text-[color:var(--text-primary)] group-hover:text-[#F85E00] transition-colors pr-12">
									{event.data.title}
								</h3>
								<p class="mt-2 text-sm text-[color:var(--text-secondary)] line-clamp-2">
									{event.data.description}
								</p>
							</div>

							<div class="mt-6 flex items-center justify-between border-t border-[color:var(--glass-border)] pt-4">
								<span class="text-xs font-bold text-[#F85E00] uppercase tracking-wider">
									{formattedDate}
								</span>
								<span class="text-xs font-semibold text-[color:var(--text-primary)] flex items-center gap-0.5 group-hover:text-[#F85E00] transition-colors">
									Details
									<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
									</svg>
								</span>
							</div>
						</a>
					);
				})}
			</div>
		) : (
			<div class="bg-[color:var(--glass-bg)] border border-[color:var(--glass-border)] rounded-3xl p-8 text-center text-[color:var(--text-secondary)] backdrop-blur-[24px]">
				No upcoming events scheduled at the moment. Explore our <a href="/events" class="text-[#F85E00] hover:underline font-semibold">past events history</a>.
			</div>
		)}
	</div>

	<!-- Socials Section -->
	<div class="max-w-4xl mx-auto px-6 mb-32">
		<h2 class="text-2xl md:text-3xl font-bold tracking-tight text-[color:var(--text-primary)] mb-8">
			Connect With Us
		</h2>
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
			{socials.map((social) => (
				<a 
					href={social.url} 
					target="_blank" 
					rel="noopener noreferrer"
					class="group relative block bg-[color:var(--glass-bg)] border border-[color:var(--glass-border)] hover:border-[#F85E00]/30 rounded-3xl p-6 backdrop-blur-[24px] shadow-[color:var(--glass-shadow)] transition-all duration-300 hover:shadow-[0_8px_32px_rgba(248,94,0,0.1)] hover:-translate-y-1"
				>
					<div class="flex items-center gap-4 mb-3">
						<div class="p-3 bg-[#F85E00]/10 text-[#F85E00] rounded-2xl group-hover:bg-[#F85E00] group-hover:text-white transition-all duration-300">
							{social.icon === 'instagram' ? (
								<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
									<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
									<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
								</svg>
							) : social.icon === 'globe' ? (
								<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"></circle>
									<line x1="2" y1="12" x2="22" y2="12"></line>
									<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
								</svg>
							) : (
								<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
									<path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
								</svg>
							)}
						</div>
						<h3 class="text-xl font-bold tracking-tight text-[color:var(--text-primary)] group-hover:text-[#F85E00] transition-colors duration-300">
							{social.name}
						</h3>
					</div>
					<p class="text-sm text-[color:var(--text-secondary)] leading-relaxed font-normal">
						{social.description}
					</p>
				</a>
			))}
		</div>
	</div>

</Layout>
