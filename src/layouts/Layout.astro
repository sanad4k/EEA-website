---
import Navbar from "../components/navbar.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>EEA Website</title>
		
		<script is:inline>
			// Inlined in head to prevent FOUC (Flash of Unstyled Content)
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
			
			if (theme === 'light') {
				document.documentElement.classList.remove('dark');
			} else {
				document.documentElement.classList.add('dark');
			}
			window.localStorage.setItem('theme', theme);
		</script>
	</head>
	<body class="bg-[color:var(--canvas-bg)] text-[color:var(--text-primary)] font-sans antialiased min-h-screen relative transition-colors duration-300">
		<!-- Background Ambient Gradient Meshes -->
		<div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
			<div class="absolute top-[-10%] left-[-10%] w-[60vw] h-[60vw] rounded-full bg-[#2A4D14]/[var(--mesh-green-opacity)] blur-[120px] transition-colors duration-300"></div>
			<div class="absolute bottom-[20%] right-[-10%] w-[70vw] h-[70vw] rounded-full bg-[#F85E00]/[var(--mesh-orange-opacity)] blur-[150px] transition-colors duration-300"></div>
			<div class="absolute top-[30%] left-[30%] w-[50vw] h-[50vw] rounded-full bg-[#F85E00]/[var(--mesh-orange-opacity)] blur-[130px] transition-colors duration-300"></div>
		</div>

		<header>
			<Navbar />
		</header>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>