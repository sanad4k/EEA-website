<div id="pagefind-search" class="w-full"></div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet">
<script src="/pagefind/pagefind-ui.js" is:inline></script>

<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    new PagefindUI({ 
      element: "#pagefind-search", 
      showSubResults: true,
      showImages: false
    });
  });
</script>

<style is:global>
  /* HACK: Hide the search input on the results page.
     This makes it look like the results came directly from the navbar.
  */
  #pagefind-search .pagefind-ui__search-input {
    display: none !important;
  }
  
  /* Remove the clearing "X" button since there is no input */
  #pagefind-search .pagefind-ui__search-clear {
    display: none !important;
  }

  /* Style the results to look like premium glass cards */
  #pagefind-search {
    --pagefind-ui-text: var(--text-primary);
    --pagefind-ui-background: var(--glass-bg);
    --pagefind-ui-border: var(--glass-border);
    --pagefind-ui-primary: #F85E00;
  }
  
  #pagefind-search .pagefind-ui__result {
    border: 1px solid var(--glass-border) !important;
    border-radius: 1.5rem !important;
    padding: 1.5rem !important;
    margin-bottom: 1rem !important;
    background: var(--glass-bg) !important;
    backdrop-filter: blur(24px) !important;
    -webkit-backdrop-filter: blur(24px) !important;
    box-shadow: var(--glass-shadow) !important;
    transition: all 0.3s ease !important;
  }

  #pagefind-search .pagefind-ui__result-title {
    color: var(--text-primary) !important;
    font-weight: 700 !important;
  }

  #pagefind-search .pagefind-ui__result-excerpt {
    color: var(--text-secondary) !important;
    font-weight: 400 !important;
  }

  #pagefind-search .pagefind-ui__result-excerpt mark {
    background-color: rgba(248, 94, 0, 0.2) !important;
    color: #F85E00 !important;
    border-radius: 0.25rem !important;
    padding: 0 0.25rem !important;
  }

  #pagefind-search .pagefind-ui__message {
    color: var(--text-primary) !important;
    font-weight: 600 !important;
  }
</style>