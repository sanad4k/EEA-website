---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'Survey', href: '/survey' },
  { name: 'Interviews', href: '/interviews' },
  { name: 'Placements', href: '/placements' },
  { name: 'Events', href: '/events' },
];
---

<header class="fixed top-6 left-1/2 z-50 w-full md:w-[90%] -translate-x-1/2 transition-all">
  
  <!-- Desktop Nav -->
  <div class="hidden md:flex h-20 items-center justify-between px-10 rounded-full border border-[color:var(--glass-border)] bg-[color:var(--glass-bg)] backdrop-blur-[24px] shadow-[color:var(--glass-shadow)] transition-colors duration-300">
    <div class="flex items-center gap-4">
      <a href="/" class="group flex items-center gap-2 text-xl font-bold transition">
        <span class="text-3xl font-bold tracking-tight text-[color:var(--text-primary)] transition-colors duration-300 group-hover:text-[#F85E00]">EEA</span>
      </a>
    </div>

    <div class="flex-1 items-center justify-center px-8 flex">
      <div class="relative w-full max-w-md">
        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4">
          <svg class="h-5 w-5 text-[color:var(--text-secondary)]/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input
          type="search"
          class="desktop-search block w-full rounded-full border border-[color:var(--glass-border)] bg-[color:var(--glass-bg)] backdrop-blur-[24px] py-2 pl-12 pr-4 text-sm text-[color:var(--text-primary)] placeholder-[color:var(--text-secondary)]/50 shadow-inner focus:border-[#F85E00] focus:ring-2 focus:ring-[#F85E00]/50 focus:outline-none transition-all"
          placeholder="Search interviews, alumni..."
        />
      </div>
    </div>

    <div class="flex items-center gap-6">
      <nav class="flex gap-8">
        {navLinks.map((link) => (
          <a href={link.href} class="text-sm font-semibold text-[color:var(--text-secondary)] transition-colors duration-300 hover:text-[#F85E00]">
            {link.name}
          </a>
        ))}
      </nav>
      
      <button 
        id="theme-toggle" 
        class="h-10 w-10 rounded-full border border-[color:var(--glass-border)] bg-[color:var(--glass-bg)] flex items-center justify-center text-[#F85E00] hover:bg-white/10 dark:hover:bg-white/5 active:scale-90 transition-all cursor-pointer shadow-sm"
        aria-label="Toggle dark/light theme"
      >
        <!-- Sun Icon (visible in dark mode) -->
        <svg class="sun-icon hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <!-- Moon Icon (visible in light mode) -->
        <svg class="moon-icon block dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div class="md:hidden w-full px-4 flex items-center justify-between gap-2">
    
    <a href="/" class="bg-[color:var(--glass-bg)] backdrop-blur-[24px] text-[color:var(--text-primary)] hover:text-[#F85E00] transition-colors h-12 px-6 rounded-full flex items-center justify-center shadow-lg border border-[color:var(--glass-border)]">
      <span class="text-xl font-black tracking-tighter">EEA</span>
    </a>

    <div class="flex-1 h-12 relative shadow-lg rounded-full">
      <input
        type="search"
        class="mobile-search w-full h-full rounded-full border border-[color:var(--glass-border)] bg-[color:var(--glass-bg)] pl-4 pr-10 text-sm text-[color:var(--text-primary)] placeholder-[color:var(--text-secondary)]/50 focus:ring-2 focus:ring-[#F85E00] focus:border-[#F85E00] focus:outline-none shadow-inner"
        placeholder="Search..."
      />
      <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none">
        <svg class="h-5 w-5 text-[color:var(--text-secondary)]/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </div>

    <!-- Theme Toggle Mobile -->
    <button 
      id="theme-toggle-mobile" 
      class="h-12 w-12 bg-[color:var(--glass-bg)] border border-[color:var(--glass-border)] rounded-full flex items-center justify-center shadow-lg text-[#F85E00] active:scale-90 transition-transform cursor-pointer"
      aria-label="Toggle dark/light theme"
    >
      <svg class="sun-icon hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <svg class="moon-icon block dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>

    <button 
      id="mobile-menu-btn" 
      class="h-12 w-12 bg-[color:var(--glass-bg)] border border-[color:var(--glass-border)] rounded-full flex items-center justify-center shadow-lg active:scale-90 transition-transform text-[#F85E00]"
    >
      <span class="sr-only">Toggle menu</span>
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" class="opacity-20" />
        <line x1="8" y1="8" x2="8" y2="16" />
        <line x1="4" y1="12" x2="8" y2="12" />
        <line x1="8" y1="10" x2="16" y2="6" />
        <line x1="16" y1="6" x2="16" y2="2" />
        <line x1="8" y1="14" x2="16" y2="18" />
        <line x1="16" y1="18" x2="16" y2="22" />
        <path d="M13 18 L16 18 L15 15" /> 
      </svg>
    </button>
  </div>

  <!-- Mobile Dropdown Menu -->
  <div 
    id="mobile-menu" 
    class="fixed inset-x-4 top-24 z-40 bg-[color:var(--canvas-bg)]/95 border border-[color:var(--glass-border)] backdrop-blur-2xl rounded-3xl shadow-2xl overflow-hidden origin-top opacity-0 invisible transition-all duration-300"
  >
    <nav class="flex flex-col p-6 gap-2">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class="mobile-link block rounded-2xl px-4 py-3 text-lg font-semibold text-[color:var(--text-secondary)] hover:bg-[color:var(--glass-bg)] hover:text-[#F85E00] transition-all transform translate-y-4 opacity-0"
        >
          {link.name}
        </a>
      ))}
    </nav>
  </div>

</header>

<script>
  import gsap from 'gsap';

  // --- 1. THEME TOGGLE LOGIC ---
  const toggleTheme = () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  };

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

  // --- 2. MOBILE MENU ANIMATION ---
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const links = document.querySelectorAll('.mobile-link');
  let isMenuOpen = false;

  if (menuBtn && menu) {
    menuBtn.addEventListener('click', () => {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        gsap.set(menu, { visibility: 'visible' });
        
        gsap.fromTo(menu, 
          { scaleY: 0, opacity: 0 },
          { scaleY: 1, opacity: 1, duration: 0.4, ease: "back.out(1.2)" }
        );

        gsap.to(links, {
          y: 0,
          opacity: 1,
          duration: 0.3,
          stagger: 0.05,
          delay: 0.1
        });

      } else {
        gsap.to(links, {
          y: 10,
          opacity: 0,
          duration: 0.2
        });

        gsap.to(menu, {
          scaleY: 0,
          opacity: 0,
          duration: 0.3,
          ease: "power2.in",
          onComplete: () => gsap.set(menu, { visibility: 'hidden' })
        });
      }
    });
  }

  // --- 3. SEARCH LOGIC ---
  const searchInputs = document.querySelectorAll('input[type="search"]');

  searchInputs.forEach(input => {
    const inputEl = input as HTMLInputElement;

    inputEl.addEventListener('keydown', (e: Event) => {
      const keyEvent = e as KeyboardEvent;
      
      if (keyEvent.key === 'Enter') {
        const target = keyEvent.target as HTMLInputElement;
        
        if (target && target.value) {
          const term = target.value.trim();
          if (term) {
            window.location.href = `/search?q=${encodeURIComponent(term)}`;
          }
        }
      }
    });
  });
</script>