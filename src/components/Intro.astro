---
// src/components/Intro.astro
---

<section id="intro-section" class="py-16 px-6 bg-transparent">
  <div class="max-w-3xl mx-auto bg-[color:var(--glass-bg)] border border-[color:var(--glass-border)] rounded-3xl p-8 md:p-12 backdrop-blur-[24px] shadow-[color:var(--glass-shadow)] transition-all duration-300 hover:border-[#F85E00]/20">
    
    <h2 class="intro-item text-[#F85E00] font-bold tracking-tight text-6xl md:text-7xl mb-8 opacity-0 translate-y-8">
      Hi.
    </h2>

    <div class="space-y-6 text-lg md:text-xl text-[color:var(--text-secondary)] leading-relaxed font-normal">
      
      <p class="intro-item opacity-0 translate-y-8">
        First time at EEA? <span class="text-[color:var(--text-secondary)]/50">We keep it simple.</span>
      </p>

      <p class="intro-item opacity-0 translate-y-8">
        This platform was built from the ground up to be a tool, to be useful. 
      </p>

      <p class="intro-item opacity-0 translate-y-8">
        Inside, you’ll find a raw archive of 
        <a href="/interviews" class="underline decoration-[#F85E00] decoration-2 underline-offset-4 hover:text-[#F85E00] transition-colors text-[color:var(--text-primary)]">interview experiences</a> 
        from past batches and unfiltered talks with industry veterans. 
        We also post notices for upcoming events and surveys here.
      </p>

      <p class="intro-item font-semibold pt-4 opacity-0 translate-y-8 text-[color:var(--text-primary)]">
        Hope you find this useful. <br />
        <span class="text-[#F85E00]">Get exploring stranger.</span>
      </p>

    </div>

  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const section = document.getElementById('intro-section');
  const items = section?.querySelectorAll('.intro-item');

  if (section && items && items.length > 0) {
    
    gsap.to(items, {
      scrollTrigger: {
        trigger: section,
        start: "top 85%",
        toggleActions: "play none none reverse",
      },
      duration: 1.0,
      autoAlpha: 1, 
      y: 0,         
      ease: "power3.out", 
      stagger: 0.15 
    });
    
  }
</script>