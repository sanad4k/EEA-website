---
const { post } = Astro.props;
---

<a href={`/data/${post.slug}`} class="group relative block h-full rounded-3xl border border-[color:var(--glass-border)] bg-[color:var(--glass-bg)] backdrop-blur-[24px] p-6 shadow-[color:var(--glass-shadow)] transition-all duration-300 hover:shadow-[0_8px_32px_rgba(248,94,0,0.15)] hover:border-[#F85E00]/30 hover:bg-white/[0.05] hover:-translate-y-1">
  
  <div class="absolute top-4 right-4">
    <span class="px-3 py-1 text-xs font-semibold uppercase tracking-wider rounded-full border bg-[#F85E00]/10 text-[#F85E00] border-[#F85E00]/20">
      {post.data.category === 'alumni' ? 'Placement' : 'Interview'}
    </span>
  </div>

  <div class="mt-2">
    <p class="text-sm font-semibold text-[color:var(--text-secondary)]/50 tracking-wide uppercase">{post.data.company}</p>
    <h3 class="mt-2 text-xl font-bold text-[color:var(--text-primary)] group-hover:text-[#F85E00] transition-colors tracking-tight">
      {post.data.title}
    </h3>
    <p class="mt-2 text-sm text-[color:var(--text-secondary)]">
      By <span class="font-medium text-[color:var(--text-primary)]">{post.data.candidateName}</span> • {post.data.role}
    </p>
    <div class="mt-4 flex flex-wrap gap-2">
      {post.data.tags.map(tag => (
        <span class="px-2.5 py-1 text-xs bg-[color:var(--glass-bg)] text-[color:var(--text-secondary)]/80 border border-[color:var(--glass-border)] rounded-full">#{tag}</span>
      ))}
    </div>
  </div>
</a>